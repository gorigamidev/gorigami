---
import { games } from "../../data/fun";
---

<section id="fun">
	<div class="fun-container">
		<div class="section-label" data-i18n="fun.label">PLAYGROUND</div>
		<h2 data-i18n="fun.title">Small experiments, big fun</h2>
		<p class="intro" data-i18n="fun.intro">
			We build tools to solve problems, but we also build things just because
			we can.
		</p>

		<div class="fun-grid">
			{
				games.map((game) => (
					<div class="game-card">
						<div class="game-visual">
							<img src={game.image} alt={game.name} loading="lazy" />
							<div class="game-overlay">
								<a
									href={game.link}
									target="_blank"
									class="play-btn"
									data-i18n="fun.playNow"
								>
									Play Now →
								</a>
							</div>
						</div>
						<div class="game-info">
							<h3 data-i18n-game-field="name" data-slug={game.slug}>
								{game.name}
							</h3>
							<p
								class="game-tagline"
								data-i18n-game-field="tagline"
								data-slug={game.slug}
							>
								{game.tagline}
							</p>
							<p
								class="game-description"
								data-i18n-game-field="description"
								data-slug={game.slug}
							>
								{game.description}
							</p>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	#fun {
		width: 100%;
		padding: 10rem 10%;
		background: var(--midnight-violet);
		position: relative;
		overflow: hidden;
		color: var(--paper-white);
	}

	/* Disruptive background elements */
	#fun::before {
		content: "";
		position: absolute;
		top: -10%;
		left: -5%;
		width: 40%;
		height: 40%;
		background: radial-gradient(
			circle,
			rgba(255, 164, 84, 0.08) 0%,
			transparent 70%
		);
		z-index: 0;
	}

	.fun-container {
		max-width: 1200px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.section-label {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--sandy-brown);
		margin-bottom: 1.5rem;
		text-shadow: 0 0 10px rgba(255, 164, 84, 0.3);
	}

	#fun h2 {
		font-size: 3.5rem;
		margin-bottom: 2rem;
		font-weight: 800;
		line-height: 1.1;
		color: var(--paper-white);
	}

	.intro {
		font-size: 1.25rem;
		color: var(--light-gray);
		margin-bottom: 5rem;
		max-width: 600px;
		opacity: 0.8;
	}

	.fun-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 4rem;
	}

	.game-card {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
	}

	.game-card:hover {
		transform: translateY(-8px);
	}

	.game-visual {
		width: 100%;
		aspect-ratio: 16/9;
		background: var(--midnight-violet-soft);
		border: 1px solid rgba(255, 255, 255, 0.1);
		overflow: hidden;
		position: relative;
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
	}

	.game-visual img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
		filter: saturate(0.8) contrast(1.1);
	}

	.game-card:hover .game-visual img {
		transform: scale(1.05);
		filter: saturate(1) contrast(1.1);
	}

	.game-overlay {
		position: absolute;
		inset: 0;
		background: rgba(22, 9, 29, 0.6);
		backdrop-filter: blur(4px);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.game-card:hover .game-overlay {
		opacity: 1;
	}

	.play-btn {
		padding: 1.25rem 2.5rem;
		background: var(--paper-white);
		color: var(--midnight-violet);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition: all 0.3s ease;
		border: none;
	}

	.play-btn:hover {
		background: var(--sandy-brown);
		color: var(--paper-white);
		transform: scale(1.05);
		box-shadow: 0 0 30px rgba(255, 164, 84, 0.4);
	}

	.game-info h3 {
		font-size: 2rem;
		margin-bottom: 0.5rem;
		color: var(--paper-white);
	}

	.game-tagline {
		font-size: 1rem;
		color: var(--sandy-brown);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 1.5rem;
	}

	.game-description {
		font-size: 1.1rem;
		line-height: 1.7;
		color: var(--light-gray);
		opacity: 0.7;
	}

	@media screen and (max-width: 1024px) {
		.fun-grid {
			gap: 3rem;
		}
	}

	@media screen and (max-width: 768px) {
		#fun {
			padding: 6rem 1.5rem;
		}

		#fun h2 {
			font-size: 2.5rem;
		}

		.fun-grid {
			grid-template-columns: 1fr;
			gap: 4rem;
		}

		.game-info h3 {
			font-size: 1.75rem;
		}
	}
</style>
